@{
    ViewBag.Title = "Погода в Москве";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WeatherPowerTest - Погода в Москве</title>
    <link href="https://fonts.googleapis.com/css2?family=Segoe+UI:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            background: rgba(255, 255, 255, 0.95);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }

        h1 {
            text-align: center;
            color: #333;
            margin-bottom: 10px;
            font-size: 2.5em;
        }

        .subtitle {
            text-align: center;
            color: #666;
            margin-bottom: 30px;
            font-size: 0.9em;
        }

        h2 {
            color: #555;
            margin-bottom: 20px;
            border-left: 4px solid #667eea;
            padding-left: 15px;
        }

        .loading {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 50px;
        }

        .spinner {
            border: 4px solid #f3f3f3;
            border-top: 4px solid #667eea;
            border-radius: 50%;
            width: 50px;
            height: 50px;
            animation: spin 1s linear infinite;
            margin-bottom: 20px;
        }

        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .error {
            text-align: center;
            padding: 50px;
            background: #fee;
            border-radius: 10px;
            margin: 20px 0;
        }

        .error p {
            color: #c33;
            margin-bottom: 20px;
            font-size: 1.2em;
        }

        .retry-btn {
            background: #667eea;
            color: white;
            border: none;
            padding: 10px 30px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 1em;
            transition: background 0.3s;
        }

        .retry-btn:hover {
            background: #5a67d8;
        }

        .current-weather {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 15px;
            padding: 25px;
            margin-bottom: 30px;
            color: white;
        }

        .current-weather h2 {
            color: white;
            border-left-color: white;
        }

        .current-info {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
        }

        .temp {
            font-size: 3.5em;
            font-weight: bold;
        }

        .temp-unit {
            font-size: 0.5em;
            vertical-align: super;
        }

        .condition {
            text-align: center;
        }

        .condition img {
            width: 80px;
            height: 80px;
        }

        .condition span {
            display: block;
            font-size: 1.2em;
            margin-top: 10px;
        }

        .details {
            text-align: right;
        }

        .details div {
            margin: 5px 0;
            font-size: 1em;
        }

        .hourly-list {
            display: flex;
            overflow-x: auto;
            gap: 15px;
            padding: 10px 0;
            margin-bottom: 30px;
        }

        .hourly-card {
            min-width: 100px;
            background: #f8f9fa;
            border-radius: 10px;
            padding: 15px;
            text-align: center;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            transition: transform 0.3s;
        }

        .hourly-card:hover {
            transform: translateY(-5px);
        }

        .hour-time {
            font-weight: bold;
            color: #667eea;
            margin-bottom: 10px;
        }

        .hourly-card img {
            width: 50px;
            height: 50px;
            margin: 10px 0;
        }

        .hour-temp {
            font-size: 1.2em;
            font-weight: bold;
            margin: 5px 0;
        }

        .hour-rain {
            font-size: 0.85em;
            color: #666;
        }

        .forecast-list {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }

        .forecast-card {
            background: #f8f9fa;
            border-radius: 10px;
            padding: 20px;
            text-align: center;
            transition: transform 0.3s;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .forecast-card:hover {
            transform: translateY(-5px);
        }

        .forecast-date {
            font-size: 1.2em;
            font-weight: bold;
            color: #667eea;
            margin-bottom: 10px;
        }

        .forecast-card img {
            width: 60px;
            height: 60px;
            margin: 10px 0;
        }

        .forecast-temp {
            font-size: 1.3em;
            font-weight: bold;
            margin: 10px 0;
        }

        .forecast-condition {
            color: #666;
        }

        .cache-badge {
            position: fixed;
            bottom: 10px;
            right: 10px;
            background: rgba(0,0,0,0.7);
            color: #4caf50;
            padding: 5px 10px;
            border-radius: 5px;
            font-size: 11px;
            font-family: monospace;
            z-index: 1000;
        }

        @@media (max-width: 768px) {
            .container {
                padding: 15px;
            }

            h1 {
                font-size: 1.8em;
            }

            .temp {
                font-size: 2.5em;
            }

            .current-info {
                flex-direction: column;
                text-align: center;
            }

            .details {
                text-align: center;
            }

            .hourly-card {
                min-width: 80px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>WeatherPowerTest</h1>
        <div class="subtitle">Clean Architecture | DDD | CQRS | Москва</div>

        <div id="loading" class="loading">
            <div class="spinner"></div>
            <p>Загрузка данных...</p>
        </div>

        <div id="error" class="error" style="display:none;">
            <p>Не удалось загрузить данные о погоде</p>
            <button id="retryBtn" class="retry-btn">Повторить запрос</button>
        </div>

        <div id="weatherContent" style="display:none;">
            <div class="current-weather">
                <h2>Сейчас</h2>
                <div class="current-info">
                    <div class="temp">
                        <span id="currentTemp"></span>
                        <span class="temp-unit">°C</span>
                    </div>
                    <div class="condition">
                        <img id="currentIcon" src="" alt="weather icon" />
                        <span id="currentCondition"></span>
                    </div>
                    <div class="details">
                        <div>Ветер: <span id="windSpeed"></span> км/ч</div>
                        <div>Влажность: <span id="humidity"></span>%</div>
                        <div>Обновлено: <span id="lastUpdated"></span></div>
                    </div>
                </div>
            </div>

            <div class="hourly-weather">
                <h2>Почасовой прогноз</h2>
                <div id="hourlyList" class="hourly-list"></div>
            </div>

            <div class="forecast-weather">
                <h2>Прогноз на 3 дня</h2>
                <div id="forecastList" class="forecast-list"></div>
            </div>
        </div>
    </div>

    <div id="cacheBadge" class="cache-badge" style="display:none;"></div>

    <script>
        const API_URL = '/api/weather/getweather';

        document.addEventListener('DOMContentLoaded', function() {
            loadWeather();
            const retryBtn = document.getElementById('retryBtn');
            if (retryBtn) {
                retryBtn.addEventListener('click', loadWeather);
            }
        });

        async function loadWeather() {
            showLoading();
            hideError();
            hideContent();
            hideCacheBadge();

            try {
                const response = await fetch(API_URL);
                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}`);
                }
                const data = await response.json();
                displayWeather(data);
                hideLoading();
                showContent();

                if (data.IsFromCache) {
                    showCacheBadge();
                }
            } catch (error) {
                console.error('Error:', error);
                hideLoading();
                showError();
            }
        }

        function displayWeather(data) {
            document.getElementById('currentTemp').textContent = Math.round(data.Current.TempC);
            document.getElementById('currentIcon').src = data.Current.ConditionIcon;
            document.getElementById('currentCondition').textContent = data.Current.ConditionText;
            document.getElementById('windSpeed').textContent = data.Current.WindKph;
            document.getElementById('humidity').textContent = data.Current.Humidity;
            document.getElementById('lastUpdated').textContent = data.Current.LastUpdated;

            const hourlyContainer = document.getElementById('hourlyList');
            hourlyContainer.innerHTML = '';
            if (data.Hourly && data.Hourly.length > 0) {
                data.Hourly.forEach(hour => {
                    const card = document.createElement('div');
                    card.className = 'hourly-card';
                    card.innerHTML = `
                        <div class="hour-time">${hour.Time}</div>
                        <img src="${hour.ConditionIcon}" alt="icon" onerror="this.src='https://cdn.weatherapi.com/weather/64x64/day/113.png'" />
                        <div class="hour-temp">${Math.round(hour.TempC)}°C</div>
                        <div class="hour-rain">🌧️ ${Math.round(hour.ChanceOfRain)}%</div>
                    `;
                    hourlyContainer.appendChild(card);
                });
            } else {
                hourlyContainer.innerHTML = '<p>Нет данных</p>';
            }

            const forecastContainer = document.getElementById('forecastList');
            forecastContainer.innerHTML = '';
            if (data.Forecast && data.Forecast.length > 0) {
                data.Forecast.forEach(day => {
                    const card = document.createElement('div');
                    card.className = 'forecast-card';
                    card.innerHTML = `
                        <div class="forecast-date">${day.Date}</div>
                        <img src="${day.ConditionIcon}" alt="icon" onerror="this.src='https://cdn.weatherapi.com/weather/64x64/day/113.png'" />
                        <div class="forecast-temp">${Math.round(day.MinTempC)}° / ${Math.round(day.MaxTempC)}°C</div>
                        <div class="forecast-condition">${day.ConditionText}</div>
                    `;
                    forecastContainer.appendChild(card);
                });
            } else {
                forecastContainer.innerHTML = '<p>Нет данных</p>';
            }
        }

        function showLoading() {
            document.getElementById('loading').style.display = 'flex';
        }

        function hideLoading() {
            document.getElementById('loading').style.display = 'none';
        }

        function showError() {
            document.getElementById('error').style.display = 'block';
        }

        function hideError() {
            document.getElementById('error').style.display = 'none';
        }

        function showContent() {
            document.getElementById('weatherContent').style.display = 'block';
        }

        function hideContent() {
            document.getElementById('weatherContent').style.display = 'none';
        }

        function showCacheBadge() {
            const badge = document.getElementById('cacheBadge');
            badge.textContent = '📦 Данные из кэша';
            badge.style.display = 'block';
            setTimeout(() => {
                badge.style.opacity = '0';
                setTimeout(() => {
                    badge.style.display = 'none';
                    badge.style.opacity = '1';
                }, 2000);
            }, 3000);
        }

        function hideCacheBadge() {
            document.getElementById('cacheBadge').style.display = 'none';
        }
    </script>
</body>
</html>